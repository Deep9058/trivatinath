{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    { "src": "api/register.js",      "use": "@vercel/node" },
    { "src": "api/registrations.js", "use": "@vercel/node" },
    { "src": "public/**",            "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/register",       "dest": "/api/register.js" },
    { "src": "/api/registrations",  "dest": "/api/registrations.js" },
    { "src": "/(.*)",               "dest": "/public/$1" }
  ]
}
